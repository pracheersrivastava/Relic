# Frontend Environment Variables for Vercel
# Copy this to your Vercel project environment variables

# Backend API URL (replace with your deployed backend URL)
NEXT_PUBLIC_API_URL=https://your-backend-url.vercel.app/api/v1
NEXT_PUBLIC_API_BASE_URL=https://your-backend-url.vercel.app/api/v1

# Stripe Public Key (for client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
